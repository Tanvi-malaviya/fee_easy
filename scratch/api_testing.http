@baseUrl = http://127.0.0.1:8000/api/v1
@instituteToken = YOUR_INSTITUTE_TOKEN_HERE

### ------------------------------------------------------------
### 1. INSTITUTE AUTH
### ------------------------------------------------------------
# Login
POST {{baseUrl}}/institute/login
Accept: application/json
Content-Type: application/json

{
    "email": "institute@example.com",
    "password": "password"
}

### ------------------------------------------------------------
### 3. INSTITUTE STUDENTS (Requires Institute Token)
### ------------------------------------------------------------
# List Students (Paginated)
GET {{baseUrl}}/institute/students
Accept: application/json
Authorization: Bearer {{instituteToken}}

# Create Student
POST {{baseUrl}}/institute/students
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{instituteToken}}

{
    "name": "Tanvi Malaviya",
    "email": "tanvi@example.com",
    "password": "password",
    "phone": "9876543210",
    "address": "Rajkot, Gujarat",
    "batch_id": 1
}

### ------------------------------------------------------------
### 4. INSTITUTE BATCHES (Requires Institute Token)
### ------------------------------------------------------------
# List Batches
GET {{baseUrl}}/institute/batches
Accept: application/json
Authorization: Bearer {{instituteToken}}

# Create Batch
POST {{baseUrl}}/institute/batches
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{instituteToken}}

{
    "batch_name": "Morning Batch A",
    "batch_time": "08:00 AM - 10:00 AM"
}

### ------------------------------------------------------------
### 7. INSTITUTE FEES & PAYMENTS
### ------------------------------------------------------------
# Assign Fee
POST {{baseUrl}}/institute/fees
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{instituteToken}}

{
    "student_id": 1,
    "total_amount": 5000,
    "month": "April",
    "year": 2026
}

# Collect Payment (Flattened Response)
POST {{baseUrl}}/institute/payments
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{instituteToken}}

{
    "fee_id": 1,
    "amount": 2000,
    "payment_method": "Cash",
    "transaction_id": "REC12345"
}

### ------------------------------------------------------------
### 9. RECEIPTS
### ------------------------------------------------------------
# List Student Receipts
GET {{baseUrl}}/institute/receipts/1
Accept: application/json
Authorization: Bearer {{instituteToken}}

# Download Receipt (In Postman, use "Send and Download")
GET {{baseUrl}}/institute/receipt/1/download
Accept: application/json
Authorization: Bearer {{instituteToken}}

### ------------------------------------------------------------
### 10. ATTENDANCE
### ------------------------------------------------------------
# Bulk Mark Attendance
POST {{baseUrl}}/institute/attendance
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{instituteToken}}

{
    "batch_id": 1,
    "date": "2024-04-14",
    "attendance": [
        {"student_id": 1, "status": "present"},
        {"student_id": 2, "status": "absent"},
        {"student_id": 3, "status": "late"}
    ]
}

# Get Attendance Records
GET {{baseUrl}}/institute/attendance?date=2024-04-14&batch_id=1
Accept: application/json
Authorization: Bearer {{instituteToken}}

### ------------------------------------------------------------
### 8. PAGINATION TESTING
### ------------------------------------------------------------
# Test Page 2
GET {{baseUrl}}/institute/students?page=2
Accept: application/json
Authorization: Bearer {{instituteToken}}
